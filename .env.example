# Copier ce fichier en .env.local et renseigner les valeurs (Dashboard Supabase → Settings → API).
# Ne jamais committer .env.local.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Obligatoire côté serveur (ne pas préfixer par NEXT_PUBLIC).
SUPABASE_SERVICE_ROLE_KEY=

# Optionnel — pour appliquer les migrations SQL en local (npm run db:apply-peak-bands).
# Dashboard Supabase → Settings → Database → Connection string (URI, Session).
# SUPABASE_DB_URL=postgresql://postgres.[ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres
# Ou mot de passe seul (URI construite depuis NEXT_PUBLIC_SUPABASE_URL) :
# SUPABASE_DB_PASSWORD=

# Optionnel : même URL que NEXT_PUBLIC_SUPABASE_URL si tu préfères une variable dédiée au serveur.
# SUPABASE_URL=

# Optionnel : fonctionnalités d’analyse (menu, tickets, factures).
# OPENAI_API_KEY=

# Tripo3D — génération de modèles 3D à partir de photos (fiche plat / RA).
# https://platform.tripo3d.ai/ → API Keys
# TRIPO_API_KEY=tsk_...
# Version modèle (optionnel) : v3.1-20260211 = qualité max H3 (défaut). Ex. v2.0-20240919 pour H2.
# TRIPO_MODEL_VERSION=v3.1-20260211
# Étape 2 post-traitement (texture_model sur v3, refine sur v2). Défaut = activé. TRIPO_REFINE_STEP=false pour désactiver.

# E-mails transactionnels (Resend) — confirmation résa, etc.
# https://resend.com — domaine d’envoi vérifié de préférence en production.
# RESEND_API_KEY=
# Expéditeur (ex. "Réservations <reservations@ton-domaine.com>").
# MESSAGING_FROM_EMAIL=onboarding@resend.dev
# URL publique pour les liens dans les e-mails (sinon Vercel / localhost en dev).
# NEXT_PUBLIC_APP_URL=http://127.0.0.1:3000

# Carte interactive Google Maps (portail public B2C).
# Console Google Cloud → APIs & Services → Maps JavaScript API activée.
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Google Business Profile — OAuth (Modifier le restaurant → Fiche Google).
# Console Google Cloud → Credentials → OAuth 2.0 Client ID (Web).
# APIs à activer : Business Profile, My Business Account Management, My Business Business Information.
# URI de redirection : http://127.0.0.1:3000/api/google/oauth/callback (adapter en prod).
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# GOOGLE_OAUTH_REDIRECT_URI=
# GOOGLE_OAUTH_STATE_SECRET=
# NEXT_PUBLIC_APP_URL=http://127.0.0.1:3000

# Meta (Facebook / Instagram) — stories + liaison page (Modifier le restaurant → Instagram & Facebook).
# developers.facebook.com → App → Facebook Login → Valid OAuth Redirect URIs :
# http://127.0.0.1:3000/api/meta/oauth/callback
# Préférer localhost (pas 127.0.0.1) — Meta l'accepte en mode Développement.
# NEXT_PUBLIC_APP_URL=http://localhost:3000
# META_APP_ID=
# META_APP_SECRET=
# META_OAUTH_REDIRECT_URI=http://localhost:3000/meta/oauth/complete
# META_OAUTH_STATE_SECRET=

# Connexion de test locale pour l'agent/outillage (route /api/dev/login).
# Inerte en production (triple verrou : NODE_ENV, flag, localhost uniquement).
# DEV_TEST_LOGIN=1
# DEV_TEST_LOGIN_EMAIL=dev-test@ubion.local
